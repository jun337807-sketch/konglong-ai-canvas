# Server
# 阿里云部署时建议使用 3202 或 3203，避免占用现有 aivideo/backend 的 3201。
PORT=3202
NODE_ENV=production
# 留空表示开发/内网调试时允许所有来源；生产如果前后端分域，填写前端域名，例如：https://canvas.example.com
CORS_ORIGIN=

# Default local admin
# 首次初始化 SQLite 时会创建 admin 用户。
# 生产环境必须填写；开发环境未填写时才会回退到 admin。
DEFAULT_ADMIN_PASSWORD=change-me
SESSION_TTL_DAYS=14

# Google Gemini / AI Studio compatibility
GEMINI_API_KEY=

# Volcengine TOS object storage
# 不要把真实密钥提交到 GitHub；只在服务器 .env 中填写。
TOS_ACCESS_KEY_ID=
TOS_ACCESS_KEY_SECRET=
TOS_BUCKET=konglong
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
# 如果你绑定了 CDN 或自定义域名，填写例如：https://cdn.example.com
TOS_PUBLIC_BASE_URL=

# Generated asset ingest
# true 时，生成结果会尝试从外部 URL 转存到 TOS；失败不影响生成主流程。
ASSET_INGEST_TO_TOS=false
ASSET_INGEST_MAX_BYTES=209715200

# External image/video provider adapters
# 后端统一生成入口：
# POST /api/generation/image
# POST /api/generation/video
# GET  /api/generation/video/:providerTaskId
IMAGE_PROVIDER=openai-compatible
# 例如：https://api.duolapi.cn
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
# 可选：为每个前端模型配置独立令牌。用于 duolapi 这类“令牌绑定分组”的服务。
# 未配置时会回退到 IMAGE_API_KEY。
IMAGE_API_KEY_KONGLONG_IMAGE=
IMAGE_API_KEY_KONGLONG_BANANA_2=
IMAGE_API_KEY_KONGLONG_BANANA_2_2K=
IMAGE_API_KEY_KONGLONG_BANANA_2_4K=
IMAGE_API_KEY_KONGLONG_BANANA_PRO=
IMAGE_API_KEY_KONGLONG_MJ=
# 默认不允许图片 API 失败后静默走免费测试图源；生产环境请保持 false 或不配置。
VITE_ENABLE_IMAGE_FALLBACK=false
# 如果你的图片服务不是 OpenAI 风格路径，请在这里改成实际提交路径。
IMAGE_API_SUBMIT_PATH=/v1/images/generations
IMAGE_API_EDIT_PATH=/v1/images/edits
IMAGE_RESPONSE_FORMAT=b64_json
# duolapi / gpt-image 当前要求最长边 <= 3840；前端仍显示 4K。
IMAGE_MAX_EDGE_PIXELS=3840
IMAGE_MODEL=gpt-image-2
IMAGE_MODEL_KONGLONG_IMAGE=gpt-image-2
IMAGE_MODEL_KONGLONG_BANANA_2=gemini-3.1-flash-image-preview
IMAGE_MODEL_KONGLONG_BANANA_2_2K=gemini-3.1-flash-image-preview-2k
IMAGE_MODEL_KONGLONG_BANANA_2_4K=gemini-3.1-flash-image-preview-4k
IMAGE_MODEL_KONGLONG_BANANA_PRO=gemini-3-pro-image-preview
IMAGE_MODEL_KONGLONG_MJ=mj_imagine
# 默认 openai-compatible：KONGLONG MJ 作为 duolapi 图片分组模型走 /v1/images/generations。
# 只有接入独立 MidJourney Proxy 时才改为 mj-proxy。
IMAGE_MJ_PROTOCOL=openai-compatible
IMAGE_MJ_API_BASE_URL=
IMAGE_MJ_SUBMIT_PATH=/mj/submit/imagine
IMAGE_MJ_TASK_PATH_TEMPLATE=/mj/task/{taskId}/fetch
IMAGE_MJ_POLL_INTERVAL_MS=3000
IMAGE_MJ_POLL_TIMEOUT_MS=180000

VIDEO_PROVIDER=mjapi-monthly
VIDEO_API_BASE_URL=https://api.mjapi.cc.cd
VIDEO_API_KEY=
VIDEO_API_AUTH_MODE=monthly-key
VIDEO_API_SUBMIT_PATH=/v1/monthly/generate
VIDEO_API_QUERY_PATH=/v1/monthly/task
VIDEO_MODEL=r_sd2
VIDEO_RESOLUTION=720p
VIDEO_WATERMARK=true
# true 时，视频参考素材会先转存到 TOS，避免中文文件名/临时 URL 导致第三方视频 API 识别失败。
VIDEO_REFERENCE_INGEST_TO_TOS=false
