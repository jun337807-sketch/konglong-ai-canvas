# Server
# 阿里云部署时建议使用 3202 或 3203，避免占用现有 aivideo/backend 的 3201。
PORT=3202
NODE_ENV=production
# 留空表示开发/内网调试时允许所有来源；生产如果前后端分域，填写前端域名，例如：https://canvas.example.com
CORS_ORIGIN=

# Default local admin
# 首次初始化 SQLite 时会创建 admin 用户。
# 生产环境必须填写；开发环境未填写时才会回退到 admin。
DEFAULT_ADMIN_PASSWORD=change-me
SESSION_TTL_DAYS=14

# Google Gemini / AI Studio compatibility
GEMINI_API_KEY=

# Volcengine TOS object storage
# 不要把真实密钥提交到 GitHub；只在服务器 .env 中填写。
TOS_ACCESS_KEY_ID=
TOS_ACCESS_KEY_SECRET=
TOS_BUCKET=konglong
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
# 如果你绑定了 CDN 或自定义域名，填写例如：https://cdn.example.com
TOS_PUBLIC_BASE_URL=

# Generated asset ingest
# true 时，生成结果会尝试从外部 URL 转存到 TOS；失败不影响生成主流程。
ASSET_INGEST_TO_TOS=false
ASSET_INGEST_MAX_BYTES=209715200

# External image/video provider adapters
# 后端统一生成入口：
# POST /api/generation/image
# POST /api/generation/video
# GET  /api/generation/video/:providerTaskId
IMAGE_PROVIDER=external-image
# 例如：https://api.example.com
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
# 如果你的图片服务不是 OpenAI 风格路径，请在这里改成实际提交路径。
IMAGE_API_SUBMIT_PATH=/v1/images/generations

VIDEO_PROVIDER=volcengine-seedance
VIDEO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VIDEO_API_KEY=
VIDEO_MODEL=doubao-seedance-2-0-260128
VIDEO_WATERMARK=true
